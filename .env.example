# --- Required ---

# PostgreSQL connection string (Neon, Supabase, or local Postgres)
DATABASE_URL="postgresql://user:password@localhost:5432/foresail_dev"

# Session signing secret — generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-long-random-string"

# Canonical URL of the deployment (no trailing slash)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Optional ---

# Direct (non-pooled) connection for migrations when DATABASE_URL points at a pooler
# DIRECT_DATABASE_URL="postgresql://user:password@host/db"

# Auth.js: set to "true" when running behind a proxy / non-Vercel host
AUTH_TRUST_HOST="true"

# Resend API key for transactional email (verification + password reset).
# If unset, the app runs in "demo mail mode": links are shown on-screen instead of emailed.
# RESEND_API_KEY="re_..."
# EMAIL_FROM="Foresail <notifications@yourdomain.com>"

# Shared secret protecting the nightly demo-workspace reset endpoint (/api/cron/reset-demo)
CRON_SECRET="replace-with-a-random-string"
